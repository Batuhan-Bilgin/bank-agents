# ============================================================
# BankAI Configuration — copy to .env and fill in values
# ============================================================

# ─── AI Provider ─────────────────────────────────────────────
PROVIDER=groq
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ─── KKB — Kredi Kayıt Bürosu ────────────────────────────────
# KKB_BASE_URL=https://api.kkb.com.tr/v2
# KKB_CLIENT_ID=your_client_id
# KKB_CLIENT_SECRET=your_client_secret
# KKB_MEMBER_CODE=your_member_code

# ─── MASAK ────────────────────────────────────────────────────
# MASAK_BASE_URL=https://api.masak.gov.tr/v1
# MASAK_API_KEY=your_masak_api_key
# MASAK_INSTITUTION_CODE=your_institution_code

# ─── T24 / Temenos Core Banking ──────────────────────────────
# T24_BASE_URL=http://your-t24-host:9089/irf-provider-container/api/v1.0.0
# T24_USERNAME=your_username
# T24_PASSWORD=your_password
# T24_COMPANY_ID=TR0010001

# ─── TCMB EVDS — Free FX Rate API (register at evds2.tcmb.gov.tr)
# TCMB_API_KEY=your_evds_api_key

# ─── SWIFT Alliance Gateway ──────────────────────────────────
# SWIFT_BASE_URL=https://api.swiftnet.sipn.swift.com/swift-preval-pilot/v3
# SWIFT_CONSUMER_KEY=your_consumer_key
# SWIFT_CONSUMER_SECRET=your_consumer_secret
# SWIFT_BIC=BANKTRISBXXX

# ─── Integration settings ────────────────────────────────────
USE_MOCK_INTEGRATIONS=true
INTEGRATION_HTTP_TIMEOUT=15.0
INTEGRATION_HTTP_RETRIES=3

AUDIT_DB_URL=sqlite:///audit.db
ALERT_EMAIL=risk-ops@bank.com
